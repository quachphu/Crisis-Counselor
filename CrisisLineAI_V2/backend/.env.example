# CrisisLine AI v2 — Backend Environment Variables
# Copy to .env and fill in your keys.

# ── Pipecat Cloud ────────────────────────────────────────────────────────────
PIPECAT_API_KEY=
PIPECAT_ORG_NAME=          # get from: pc cloud organizations list

# ── NVIDIA Nemotron (pre-hosted on AWS — use these exactly during hackathon) ─
NVIDIA_ASR_URL=ws://44.241.251.184:8080
NEMOTRON_LLM_URL=http://nemotron-fleet-alb-1322439314.us-west-2.elb.amazonaws.com/v1
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_ENABLE_THINKING=false

# ── Gradium (TTS — also used as STT fallback) ────────────────────────────────
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=_6Aslh2DxfmnRLmP

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Pipecat Cloud stream URL (Twilio webhook target) ─────────────────────────
PIPECAT_STREAM_URL=wss://api.pipecat.daily.co/ws/twilio

# ── Firebase (Firestore live sync for counselor dashboard) ───────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── OpenAI (LLM fallback + auto-improve prompt optimizer) ───────────────────
OPENAI_API_KEY=

# ── Cekura (automated scenario evaluation) ───────────────────────────────────
CEKURA_API_KEY=

# ── Legacy CrisisLineAI backend vars (kept for compatibility) ────────────────
